# ═══════════════════════════════════════════════════════════════
# vLLM API Server — 환경변수 설정
# ═══════════════════════════════════════════════════════════════
# start.sh가 configs/*.yaml 기반으로 .env를 자동 생성합니다.
#
# vLLM 버전 (2026.03 기준):
#   v0.17.1  — 최신 안정 릴리스 (2026-03-11, 기본값)
#   v0.18.0  — PyPI 최신 (gRPC 지원, nested YAML config 등)
#   nightly  — 최신 개발 빌드 (Qwen3.5 등 신규 모델 지원 시 필요)
# ═══════════════════════════════════════════════════════════════

# ── vLLM Docker 이미지 ──
VLLM_IMAGE_TAG=v0.17.1

# ── HuggingFace ──
HF_TOKEN=
HF_CACHE=/root/.cache/huggingface

# ── GPU ──
NVIDIA_VISIBLE_DEVICES=all
NCCL_IB_DISABLE=1
NCCL_P2P_DISABLE=0

# ── Reranker ──
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_PORT=8001
RERANKER_TP=1
RERANKER_GPU_UTIL=0.05
RERANKER_GPU=all

# ── 아래는 start.sh가 자동 생성 ──
# MODEL_NAME=qwen3-32b-awq
# HOST_PORT=8000
# VLLM_CMD_ARGS=--model Qwen/Qwen3-32B-AWQ --host 0.0.0.0 ...
