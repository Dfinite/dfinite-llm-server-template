# ═══════════════════════════════════════════════════════════════
# vLLM API Server — 환경변수 설정
# ═══════════════════════════════════════════════════════════════
# start.sh가 configs/*.yaml 기반으로 .env를 자동 생성합니다.
#
# vLLM 버전 가이드 (2026.03 기준):
#   v0.17.1  — 최신 안정 (Qwen3, Nemotron 등 기존 모델 OK)
#   v0.18.0  — PyPI 최신 (gRPC, nested YAML config)
#   nightly  — Qwen3.5 등 신규 아키텍처 지원 (Transformers v5 포함)
#
# ⚠️ Qwen3.5 모델 사용 시:
#   1. 먼저 nightly 시도: ./start.sh qwen3.5-27b --tag nightly
#   2. nightly 안 되면 커스텀 빌드:
#      docker build -t vllm-qwen3.5 -f Dockerfile.qwen3.5 .
#      VLLM_IMAGE_TAG=vllm-qwen3.5 으로 설정
# ═══════════════════════════════════════════════════════════════

# ── vLLM Docker 이미지 ──
# Qwen3, Nemotron 등: v0.17.1
# Qwen3.5:           nightly (또는 커스텀 빌드)
VLLM_IMAGE_TAG=v0.17.1

# ── HuggingFace ──
HF_TOKEN=
HF_CACHE=/root/.cache/huggingface

# ── GPU ──
NVIDIA_VISIBLE_DEVICES=all
NCCL_IB_DISABLE=1
NCCL_P2P_DISABLE=0

# ── Reranker ──
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_PORT=10072
RERANKER_TP=1
RERANKER_GPU_UTIL=0.05
RERANKER_GPU=all

# ── 아래는 start.sh가 자동 생성 ──
# MODEL_NAME=qwen3-32b-awq
# HOST_PORT=8000
# VLLM_CMD_ARGS=--model Qwen/Qwen3-32B-AWQ --host 0.0.0.0 ...
