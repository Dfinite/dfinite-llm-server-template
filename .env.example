# ═══════════════════════════════════════════════════════════════
# vLLM API Server — 환경변수 설정
# ═══════════════════════════════════════════════════════════════
# start.sh가 configs/*.yaml 기반으로 .env를 자동 생성합니다.
# ═══════════════════════════════════════════════════════════════

# ── vLLM Docker 이미지 ──
# v0.17.1: Qwen3, Nemotron 등 기존 모델
# v0.18.0: Qwen3.5 지원 (transformers 4.56.x 포함)
VLLM_IMAGE_TAG=v0.18.0

# ── HuggingFace ──
HF_TOKEN=
HF_CACHE=/root/.cache/huggingface

# ── GPU ──
NVIDIA_VISIBLE_DEVICES=all
NCCL_IB_DISABLE=1
NCCL_P2P_DISABLE=0

# ── Reranker ──
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_PORT=10072
RERANKER_TP=1
RERANKER_GPU_UTIL=0.05
RERANKER_GPU=all

# ── Embedding ──
# BAAI/bge-m3, dragonkue/BGE-m3-ko,
# Qwen/Qwen3-Embedding-0.6B, Qwen/Qwen3-Embedding-4B, Qwen/Qwen3-Embedding-8B
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_PORT=10073
EMBEDDING_TP=1
EMBEDDING_GPU_UTIL=0.10
EMBEDDING_GPU=all
EMBEDDING_MAX_MODEL_LEN=8192
EMBEDDING_EXTRA_ARGS=

# ── 아래는 start.sh가 자동 생성 ──
# MODEL_NAME=qwen3-32b-awq
# HOST_PORT=10071
# VLLM_CMD_ARGS=--model Qwen/Qwen3-32B-AWQ --host 0.0.0.0 ...
