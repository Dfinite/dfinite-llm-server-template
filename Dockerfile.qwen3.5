# ═══════════════════════════════════════════════════════════════
# vLLM + Transformers v5 커스텀 이미지
# ═══════════════════════════════════════════════════════════════
# Qwen3.5 모델은 Transformers v5가 필요합니다.
# vLLM 공식 이미지(v0.17.1)에 Transformers v5가 미포함된 경우
# 이 Dockerfile로 커스텀 이미지를 빌드하세요.
#
# 빌드:
#   docker build -t vllm-qwen3.5 -f Dockerfile.qwen3.5 .
#
# 사용:
#   ./start.sh qwen3.5-27b-vlm --tag qwen3.5-custom
#   (docker-compose.yaml에서 image가 vllm/vllm-openai:qwen3.5-custom이 됨)
#
# 또는 직접:
#   VLLM_IMAGE_TAG=qwen3.5-custom docker compose up -d vllm
#
# ⚠️ nightly 이미지에 이미 Transformers v5가 포함되어 있으면
#    이 Dockerfile은 불필요합니다. 먼저 nightly를 시도하세요:
#    ./start.sh qwen3.5-27b-vlm --tag nightly
# ═══════════════════════════════════════════════════════════════

ARG BASE_TAG=v0.17.1
FROM vllm/vllm-openai:${BASE_TAG}

# Transformers v5 설치 (Qwen3.5 아키텍처 지원)
RUN uv pip install --system "transformers>=5.0"

# 또는 최신 main 브랜치에서 설치 (더 최신이 필요한 경우):
# RUN uv pip install --system git+https://github.com/huggingface/transformers.git
